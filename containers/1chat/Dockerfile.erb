# Node 22 + ffmpeg (audio conversion). No canvas / ML native deps.
FROM docker.io/library/node:22-bookworm-slim

ARG DEBIAN_FRONTEND=noninteractive
ENV TZ=Etc/UTC
ENV NODE_ENV=production

RUN apt-get update && apt-get install -y --no-install-recommends \
	ca-certificates \
	ffmpeg \
	&& rm -rf /var/lib/apt/lists/*

RUN corepack enable && corepack prepare pnpm@10.32.1 --activate

WORKDIR /home/app/1chat

COPY ./containers/1chat/src/package.json ./containers/1chat/src/pnpm-lock.yaml ./containers/1chat/src/tsconfig.json ./
RUN mkdir -p data && pnpm install --frozen-lockfile

COPY ./containers/1chat/src/src/ ./src/
COPY ./containers/1chat/src/default-config/ ./default-config/

# Fresh dist: a leftover dist/piers/discord.js shadows discord/index.js for require("./discord").
# tsc recreates dist/; data/ is kept for runtime.
RUN rm -rf dist && pnpm run tsc

RUN chown -R <%= userid %>:<%= groupid %> /home/app/1chat

CMD ["pnpm", "start"]
